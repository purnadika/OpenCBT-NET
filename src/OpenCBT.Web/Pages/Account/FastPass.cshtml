@page
@model OpenCBT.Web.Pages.Account.FastPassModel
@{
    Layout = null;
    ViewData["Title"] = "Fast Pass Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OpenCBT</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#2563eb',
                        secondary: '#475569',
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-slate-50 min-h-screen flex flex-col justify-center py-12 sm:px-6 lg:px-8">

    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <div class="flex justify-center">
            <partial name="_BrandLogo" model='"w-16 h-16"' />
        </div>
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
            OpenCBT Fast Pass
        </h2>
        <p class="mt-2 text-center text-sm text-gray-600">
            Enter your NISN and Exam Token to start immediately.
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10 border-t-4 border-primary">
            
            @if (!ModelState.IsValid)
            {
                <div class="mb-4 bg-red-50 border-l-4 border-red-400 p-4">
                    <div class="flex">
                        <div class="ml-3">
                            <p class="text-sm text-red-700">
                                <div asp-validation-summary="All" class="text-danger"></div>
                            </p>
                        </div>
                    </div>
                </div>
            }

            <form class="space-y-6" method="POST">
                <div>
                    <label asp-for="Input.IdentifierNumber" class="block text-sm font-medium text-gray-700"></label>
                    <div class="mt-1">
                        <input asp-for="Input.IdentifierNumber" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" placeholder="1234567890" />
                    </div>
                    <span asp-validation-for="Input.IdentifierNumber" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.ExamToken" class="block text-sm font-medium text-gray-700"></label>
                    <div class="mt-1">
                        <input asp-for="Input.ExamToken" required class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" placeholder="ABCDEF123" />
                    </div>
                    <span asp-validation-for="Input.ExamToken" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-colors">
                        Start Exam
                    </button>
                </div>
            </form>
            
            <div class="mt-6 text-center">
                <a href="/Account/Login" class="text-sm text-primary hover:text-blue-700">Standard Login</a>
            </div>
        </div>
    </div>
</body>
</html>
