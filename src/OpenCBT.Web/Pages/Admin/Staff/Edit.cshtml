@page "{id:guid}"
@model OpenCBT.Web.Pages.Admin.Staff.EditModel
@{
    ViewData["Title"] = "Edit Staff";
}

<div class="max-w-3xl mx-auto">
    <div class="mb-6 flex justify-between items-center">
        <div>
            <h2 class="text-2xl font-bold text-gray-900">Edit Staff / Teacher</h2>
        </div>
        <div>
            <a asp-page="./Index" class="text-sm font-medium text-indigo-600 hover:text-indigo-500">Back to List</a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="rounded-md bg-red-50 p-4 mb-6">
            <div class="flex">
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">Error</h3>
                    <div class="mt-2 text-sm text-red-700">
                        <p>@TempData["ErrorMessage"]</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <div class="bg-white shadow overflow-hidden sm:rounded-lg">
        <div class="px-4 py-5 sm:p-6">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="mb-4 text-sm text-red-600 font-medium"></div>

                <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                    <div class="sm:col-span-6">
                        <label asp-for="Input.FullName" class="block text-sm font-medium text-gray-700">Full Name</label>
                        <div class="mt-1">
                            <input asp-for="Input.FullName" class="shadow-sm focus:ring-primary focus:border-primary block w-full sm:text-sm border-gray-300 rounded-md" />
                            <span asp-validation-for="Input.FullName" class="text-red-600 text-xs mt-1"></span>
                        </div>
                    </div>

                    <div class="sm:col-span-3">
                        <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700">Email Address</label>
                        <div class="mt-1">
                            <input asp-for="Input.Email" type="email" class="shadow-sm focus:ring-primary focus:border-primary block w-full sm:text-sm border-gray-300 rounded-md" />
                            <span asp-validation-for="Input.Email" class="text-red-600 text-xs mt-1"></span>
                        </div>
                    </div>

                    <div class="sm:col-span-3">
                        <label asp-for="Input.IdentifierNumber" class="block text-sm font-medium text-gray-700">Identifier Number (NIP/NUPTK)</label>
                        <div class="mt-1">
                            <input asp-for="Input.IdentifierNumber" class="shadow-sm focus:ring-primary focus:border-primary block w-full sm:text-sm border-gray-300 rounded-md" />
                            <span asp-validation-for="Input.IdentifierNumber" class="text-red-600 text-xs mt-1"></span>
                        </div>
                    </div>

                    <div class="sm:col-span-3">
                        <label asp-for="Input.Role" class="block text-sm font-medium text-gray-700">Role</label>
                        <div class="mt-1">
                            <select asp-for="Input.Role" class="shadow-sm focus:ring-primary focus:border-primary block w-full sm:text-sm border-gray-300 rounded-md">
                                <option value="Teacher">Teacher</option>
                                <option value="Admin">Administrator</option>
                            </select>
                            <span asp-validation-for="Input.Role" class="text-red-600 text-xs mt-1"></span>
                        </div>
                    </div>
                    
                    <div class="sm:col-span-6">
                        <div class="relative flex items-start">
                            <div class="flex items-center h-5">
                                <input asp-for="Input.IsActive" type="checkbox" class="focus:ring-primary h-4 w-4 text-primary border-gray-300 rounded">
                            </div>
                            <div class="ml-3 text-sm">
                                <label asp-for="Input.IsActive" class="font-medium text-gray-700">Account is Active</label>
                                <p class="text-gray-500">Uncheck to prevent this user from logging in.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pt-5 mt-6 border-t border-gray-200">
                    <div class="flex justify-end">
                        <a asp-page="./Index" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                            Cancel
                        </a>
                        <button type="submit" class="ml-3 inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                            Save Changes
                        </button>
                    </div>
                </div>
            </form>
            
            <div class="mt-8 pt-6 border-t border-gray-200">
                <h3 class="text-lg leading-6 font-medium text-gray-900">Danger Zone</h3>
                <div class="mt-2 max-w-xl text-sm text-gray-500">
                    <p>Resetting a password will generate a new secure password and force the user to change it upon their next login.</p>
                </div>
                <div class="mt-5">
                    <form method="post" asp-page-handler="ResetPassword" onsubmit="return confirm('Are you sure you want to reset this user\'s password?');">
                        <button type="submit" class="inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-red-700 bg-red-100 hover:bg-red-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:text-sm">
                            Reset Password
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
