@page "{id:guid}"
@model OpenCBT.Web.Pages.Exams.TakeModel
@{
    ViewData["Title"] = Model.Exam.Title;
}

@if (Model.RequiresTokenInput)
{
    <div class="min-h-full flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
        <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-xl shadow-lg border border-gray-100">
            <div>
                <h2 class="mt-6 text-center text-3xl font-extrabold text-slate-900">Token Ujian Required</h2>
                <p class="mt-2 text-center text-sm text-slate-500">Please enter the active 5-character token generated by your proctor/teacher to begin the exam.</p>
            </div>
            <form class="mt-8 space-y-6" method="post" asp-page-handler="StartWithToken" asp-route-id="@Model.Exam.Id">
                <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
                <div class="rounded-md shadow-sm">
                    <div>
                        <label for="token" class="sr-only">Token Ujian</label>
                        <input name="token" type="text" maxlength="5" required class="appearance-none rounded-md relative block w-full px-3 py-3 border border-slate-300 placeholder-slate-400 text-slate-900 text-center font-mono font-bold text-2xl tracking-widest uppercase focus:outline-none focus:ring-primary focus:border-primary focus:z-10" placeholder="XXXXX">
                    </div>
                </div>

                <div>
                    <button type="submit" class="group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-primary hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                        Enter Exam
                    </button>
                </div>
            </form>
        </div>
    </div>
}
else
{
    <div class="max-w-4xl mx-auto py-6 sm:px-6 lg:px-8" x-data="examApp()">
        <!-- Live Proctoring Status / Notifications / Chat overlay -->
        <div x-show="notifications.length > 0" class="fixed top-4 right-4 z-50 space-y-2 max-w-sm">
            <template x-for="notif in notifications" :key="notif.id">
                <div class="bg-blue-50 border-l-4 border-blue-400 p-4 rounded shadow-md flex justify-between items-center">
                    <div class="flex">
                        <div class="ml-3">
                            <p class="text-sm text-blue-700" x-text="notif.text"></p>
                        </div>
                    </div>
                    <button @@click="removeNotification(notif.id)" class="text-blue-500 hover:text-blue-700 text-lg font-bold ml-4">&times;</button>
                </div>
            </template>
        </div>

        <!-- Chat Panel Sticky Widget -->
        <div class="fixed bottom-4 right-4 z-50 bg-white shadow-2xl rounded-lg border border-slate-200 overflow-hidden w-80" x-data="{ open: false, msg: '' }" x-show="true">
            <button @@click="open = !open" class="bg-primary text-white w-full py-3 px-4 font-bold flex justify-between items-center">
                <span>Chat with Proctor</span>
                <span x-show="!open">&#x25B2;</span>
                <span x-show="open">&#x25BC;</span>
            </button>
            <div x-show="open" class="p-3 flex flex-col h-64">
                <div class="flex-1 overflow-y-auto space-y-2 mb-3 bg-slate-50 p-2 rounded text-xs" id="chat-box">
                    <template x-for="chat in chats" :key="chat.id">
                        <div :class="chat.sentByMe ? 'text-right' : 'text-left'">
                            <span class="inline-block px-2.5 py-1.5 rounded-lg max-w-[80%]" :class="chat.sentByMe ? 'bg-blue-100 text-blue-800' : 'bg-slate-200 text-slate-800'" x-text="chat.text"></span>
                        </div>
                    </template>
                </div>
                <div class="flex">
                    <input type="text" x-model="msg" @@keyup.enter="sendChat(); msg=''" placeholder="Type reply..." class="border border-slate-300 rounded-l-md px-2 py-1 text-xs w-full focus:outline-none focus:ring-1 focus:ring-primary">
                    <button @@click="sendChat(); msg=''" class="bg-primary text-white text-xs px-3 rounded-r-md">Send</button>
                </div>
            </div>
        </div>

        <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-6">
            <div class="px-4 py-5 sm:px-6 flex justify-between items-center">
                <div>
                    <h3 class="text-lg leading-6 font-medium text-gray-900">@Model.Exam.Title</h3>
                    <p class="mt-1 max-w-2xl text-sm text-gray-500">@Model.Exam.Description</p>
                </div>
                <div class="text-right">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
                        Time Remaining: <span x-text="formatTime(timeRemaining)" class="ml-1 font-mono font-bold"></span>
                    </span>
                </div>
            </div>
        </div>

        <!-- WIZARD MODE -->
        @if (Model.Exam.DisplayMode == OpenCBT.Domain.Enums.DisplayMode.Wizard)
        {
            <div x-show="!isSubmitting">
                <template x-for="(question, index) in questions" :key="question.id">
                    <div x-show="currentIndex === index" class="bg-white shadow overflow-hidden sm:rounded-lg mb-6 p-6">
                        <h4 class="text-lg font-bold text-gray-900 mb-4">
                            Question <span x-text="index + 1"></span> of <span x-text="questions.length"></span>
                        </h4>
                        <p class="text-gray-700 mb-6 text-lg" x-text="question.text"></p>
                        
                        <div x-show="question.options && question.options.length > 0" class="space-y-3">
                            <template x-for="option in question.options" :key="option.id">
                                <label class="flex items-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50 transition-colors"
                                       :class="{'border-primary bg-blue-50': answers[question.id] === option.id}">
                                    <input type="radio" :name="'q_' + question.id" :value="option.id" x-model="answers[question.id]" class="h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                                    <span class="ml-3 text-gray-900" x-text="option.text"></span>
                                </label>
                            </template>
                        </div>
                        <div x-show="!question.options || question.options.length === 0" class="mt-4">
                            <label class="block text-sm font-medium text-slate-700 mb-2">Your Essay Answer:</label>
                            <textarea x-model="essayAnswers[question.id]" @@blur="saveEssayAnswer(question.id)" rows="6" class="shadow-sm focus:ring-primary focus:border-primary block w-full sm:text-sm border border-slate-300 rounded-md p-3" placeholder="Type your answer here..."></textarea>
                        </div>

                        <div class="mt-8 flex justify-between">
                            <button type="button" @@click="prevQuestion()" :disabled="currentIndex === 0" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 disabled:opacity-50">
                                Previous
                            </button>
                            
                            <button x-show="currentIndex < questions.length - 1" type="button" @@click="nextQuestion(question.id)" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary hover:bg-blue-700">
                                Next
                            </button>

                            <button x-show="currentIndex === questions.length - 1" type="button" @@click="submitExam()" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-green-600 hover:bg-green-700">
                                Finish Exam
                            </button>
                        </div>
                    </div>
                </template>
            </div>
        }
        else
        {
            <!-- SINGLE PAGE MODE -->
            <div class="space-y-6" x-show="!isSubmitting">
                <template x-for="(question, index) in questions" :key="question.id">
                    <div class="bg-white shadow overflow-hidden sm:rounded-lg p-6">
                        <h4 class="text-lg font-bold text-gray-900 mb-4">
                            Question <span x-text="index + 1"></span>.
                        </h4>
                        <p class="text-gray-700 mb-6 text-lg" x-text="question.text"></p>
                        
                        <div x-show="question.options && question.options.length > 0" class="space-y-3">
                            <template x-for="option in question.options" :key="option.id">
                                <label class="flex items-center p-3 border rounded-lg cursor-pointer hover:bg-gray-50 transition-colors"
                                       :class="{'border-primary bg-blue-50': answers[question.id] === option.id}">
                                    <input type="radio" :name="'q_' + question.id" :value="option.id" x-model="answers[question.id]" 
                                           @@change="saveAnswer(question.id, option.id)" class="h-4 w-4 text-primary border-gray-300 focus:ring-primary">
                                    <span class="ml-3 text-gray-900" x-text="option.text"></span>
                                </label>
                            </template>
                        </div>
                        <div x-show="!question.options || question.options.length === 0" class="mt-4">
                            <label class="block text-sm font-medium text-slate-700 mb-2">Your Essay Answer:</label>
                            <textarea x-model="essayAnswers[question.id]" @@blur="saveEssayAnswer(question.id)" rows="6" class="shadow-sm focus:ring-primary focus:border-primary block w-full sm:text-sm border border-slate-300 rounded-md p-3" placeholder="Type your answer here..."></textarea>
                        </div>
                    </div>
                </template>

                <div class="mt-8 flex justify-end">
                    <button type="button" @@click="submitExam()" class="inline-flex items-center px-6 py-3 border border-transparent shadow-sm text-base font-medium rounded-md text-white bg-green-600 hover:bg-green-700">
                        Finish & Submit Exam
                    </button>
                </div>
            </div>
        }

        <!-- Loading State -->
        <div x-show="isSubmitting" class="text-center py-12">
            <svg class="animate-spin h-10 w-10 text-primary mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <p class="mt-4 text-lg text-gray-600">Submitting your exam...</p>
        </div>

        <!-- Hidden Form for Final Submission -->
        <form id="finishForm" method="post" asp-page-handler="FinishExam" asp-route-sessionId="@Model.Session?.Id">
        </form>
    </div>
}

@section Scripts {
    @if (!Model.RequiresTokenInput && Model.Session != null)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
        <script>
            document.addEventListener('alpine:init', () => {
                Alpine.data('examApp', () => ({
                    questions: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Exam.Questions)),
                    answers: {},
                    essayAnswers: {},
                    currentIndex: 0,
                    isSubmitting: false,
                    timeRemaining: @((int)(Model.Exam.DurationMinutes * 60 - (DateTime.UtcNow - Model.Session.StartedAt).TotalSeconds)),
                    sessionId: '@Model.Session.Id',
                    
                    // SignalR / Realtime States
                    connection: null,
                    chats: [],
                    notifications: [],
                    activeProctorConnectionId: null,

                    init() {
                        // 1. Timer Logic
                        setInterval(() => {
                            if (this.timeRemaining > 0) {
                                this.timeRemaining--;
                            } else if (this.timeRemaining === 0) {
                                this.submitExam();
                            }
                        }, 1000);

                        // 2. Real-time Proctor SignalR setup
                        this.connection = new signalR.HubConnectionBuilder()
                            .withUrl("/proctorHub")
                            .build();

                        this.connection.on("BroadcastReceived", (msg) => {
                            this.addNotification(`Broadcast: ${msg}`);
                            this.chats.push({ id: Date.now(), text: `[Broadcast] ${msg}`, sentByMe: false });
                        });

                        this.connection.on("PersonalMessageReceived", (proctorConnId, msg) => {
                            this.activeProctorConnectionId = proctorConnId;
                            this.chats.push({ id: Date.now(), text: msg, sentByMe: false });
                        });

                        this.connection.on("ForceSubmitReceived", () => {
                            this.addNotification("The proctor has forced submission of your exam.");
                            setTimeout(() => {
                                 this.submitExam();
                            }, 2000);
                        });

                        this.connection.start().then(() => {
                            this.connection.invoke("JoinExamRoom", "@Model.Exam.Id", "Student");
                            this.reportProgress();
                        }).catch(err => console.error(err.toString()));
                    },

                    formatTime(seconds) {
                        if (seconds <= 0) return "00:00";
                        const m = Math.floor(seconds / 60).toString().padStart(2, '0');
                        const s = (seconds % 60).toString().padStart(2, '0');
                        return `${m}:${s}`;
                    },

                    addNotification(text) {
                        const id = Date.now();
                        this.notifications.push({ id, text });
                        setTimeout(() => this.removeNotification(id), 8000);
                    },

                    removeNotification(id) {
                        this.notifications = this.notifications.filter(n => n.id !== id);
                    },

                    async sendChat() {
                        if (!this.msg || this.msg.trim() === "") return;
                        this.chats.push({ id: Date.now(), text: this.msg, sentByMe: true });
                        if (this.activeProctorConnectionId) {
                            await this.connection.invoke("ReplyToProctor", this.activeProctorConnectionId, this.msg);
                        } else {
                            // Default chat broadcast
                            await this.connection.invoke("ReportProgress", "@Model.Exam.Id", "Student", this.currentIndex, this.questions.length);
                        }
                    },

                    reportProgress() {
                        if (this.connection && this.connection.state === signalR.HubConnectionState.Connected) {
                            this.connection.invoke("ReportProgress", "@Model.Exam.Id", "@User.Identity?.Name", this.currentIndex, this.questions.length);
                        }
                    },

                    async saveAnswer(questionId, optionId) {
                        const formData = new FormData();
                        formData.append('CurrentQuestionId', questionId);
                        formData.append('SelectedOptionId', optionId);
                        formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                        try {
                            await fetch(`?handler=SubmitAnswer&id=@Model.Exam.Id&sessionId=${this.sessionId}`, {
                                method: 'POST',
                                body: formData
                            });
                        } catch (err) {
                            console.error('Error saving answer', err);
                        }
                    },

                    async saveEssayAnswer(questionId) {
                        const answerText = this.essayAnswers[questionId];
                        if (answerText === undefined) return;

                        const formData = new FormData();
                        formData.append('CurrentQuestionId', questionId);
                        formData.append('EssayAnswer', answerText);
                        formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                        try {
                            await fetch(`?handler=SubmitEssayAnswer&id=@Model.Exam.Id&sessionId=${this.sessionId}`, {
                                method: 'POST',
                                body: formData
                            });
                        } catch (err) {
                            console.error('Error saving essay answer', err);
                        }
                    },

                    async nextQuestion(currentQuestionId) {
                        const selectedOption = this.answers[currentQuestionId];
                        if (selectedOption) {
                            await this.saveAnswer(currentQuestionId, selectedOption);
                        }
                        const essayAns = this.essayAnswers[currentQuestionId];
                        if (essayAns !== undefined) {
                            await this.saveEssayAnswer(currentQuestionId);
                        }
                        if (this.currentIndex < this.questions.length - 1) {
                            this.currentIndex++;
                            this.reportProgress();
                        }
                    },

                    prevQuestion() {
                        if (this.currentIndex > 0) {
                            this.currentIndex--;
                            this.reportProgress();
                        }
                    },

                    submitExam() {
                        this.isSubmitting = true;
                        const currentQ = this.questions[this.currentIndex];
                        if (currentQ) {
                            if (this.answers[currentQ.id]) {
                                this.saveAnswer(currentQ.id, this.answers[currentQ.id]).then(() => {
                                    document.getElementById('finishForm').submit();
                                });
                            } else if (this.essayAnswers[currentQ.id] !== undefined) {
                                this.saveEssayAnswer(currentQ.id).then(() => {
                                    document.getElementById('finishForm').submit();
                                });
                            } else {
                                document.getElementById('finishForm').submit();
                            }
                        } else {
                            document.getElementById('finishForm').submit();
                        }
                    }
                }))
            })
        </script>
    }
}
