@page
@model OpenCBT.Web.Pages.Admin.Students.PrintCardsModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Print Student Exam Cards</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@media print {
            body {
                background-color: white;
                color: black;
            }
            .no-print {
                display: none !important;
            }
            .card-page {
                page-break-after: always;
            }
        }
        .card-box {
            width: 3.5in;
            height: 2.2in;
            border: 2px solid #000;
            padding: 10px;
            font-family: sans-serif;
            position: relative;
            background-color: #fff;
        }
    </style>
</head>
<body class="bg-gray-100 p-6 flex flex-col items-center">
    
    <!-- Printable Top Toolbar -->
    <div class="no-print mb-6 w-full max-w-4xl bg-white p-4 rounded shadow border flex justify-between items-center">
        <div>
            <h1 class="text-lg font-bold text-gray-800">Student Exam Cards</h1>
            <p class="text-xs text-gray-500">Ready to print. Cut along the borders after printing.</p>
        </div>
        <div class="flex space-x-3">
            <a asp-page="./Index" class="px-4 py-2 border text-sm font-semibold rounded hover:bg-gray-50 bg-white text-gray-700">
                Back to List
            </a>
            <button onclick="window.print()" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded text-sm shadow">
                Print Cards
            </button>
        </div>
    </div>

    <!-- Cards Grid Container -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-4xl">
        @foreach (var student in Model.Students)
        {
            <div class="bg-white p-4 border-2 border-slate-900 rounded-lg shadow-sm flex flex-col justify-between h-[2.5in] w-[4.0in] relative overflow-hidden card-page">
                <!-- Header Card Banner -->
                <div class="bg-slate-900 text-white p-1 text-center font-bold text-[10px] tracking-widest rounded-t uppercase">
                    OpenCBT eSchool Portal
                </div>
                
                <div class="flex-grow flex p-2 space-x-2">
                    <!-- Photo Box -->
                    <div class="w-20 h-24 border border-slate-300 rounded flex items-center justify-center bg-slate-50 text-[8px] text-slate-400 text-center font-semibold p-1">
                        PHOTO 2x3
                    </div>
                    
                    <!-- Details -->
                    <div class="flex-grow text-[9px] space-y-1">
                        <div>
                            <span class="font-bold text-slate-400 block uppercase text-[7px]">Name</span>
                            <span class="font-bold text-slate-800 text-[10px]" style="line-height:1.2;">@student.FullName</span>
                        </div>
                        <div class="grid grid-cols-2 gap-1">
                            <div>
                                <span class="font-bold text-slate-400 block uppercase text-[7px]">NISN / ID</span>
                                <span class="font-semibold text-slate-800 font-mono">@student.IdentifierNumber</span>
                            </div>
                            <div>
                                <span class="font-bold text-slate-400 block uppercase text-[7px]">Seeded Password</span>
                                <span class="font-semibold text-slate-800 font-mono">Student123!</span>
                            </div>
                        </div>
                        <div>
                            <span class="font-bold text-slate-400 block uppercase text-[7px]">Login Email</span>
                            <span class="font-semibold text-slate-800 font-mono">@student.Email</span>
                        </div>
                        @if (Model.Exams.Any())
                        {
                            <div>
                                <span class="font-bold text-slate-400 block uppercase text-[7px]">Scheduled Exams</span>
                                <div class="space-y-0.5">
                                    @foreach (var exam in Model.Exams.Take(2))
                                    {
                                        <div class="text-slate-800 font-semibold leading-tight text-[8px]">
                                            @exam.Title (@exam.StartTime.ToString("MMM dd, yyyy HH:mm"))
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <!-- QR Code Login Ticket -->
                    <div class="flex flex-col items-center justify-center">
                        <img src="https://api.qrserver.com/v1/create-qr-code/?size=60x60&data=@student.Email" class="w-14 h-14 border border-slate-200 p-0.5 rounded" alt="Login QR">
                        <span class="text-[6px] text-slate-400 mt-1 uppercase font-bold tracking-wider">Scan Login</span>
                    </div>
                </div>
                
                <!-- Footer Card Info -->
                <div class="border-t border-slate-200 pt-1 text-center text-[7px] text-slate-400 font-bold uppercase tracking-wider">
                    Please keep this card secure.
                </div>
            </div>
        }
        @if (!Model.Students.Any())
        {
            <div class="col-span-2 bg-white p-8 border rounded text-center text-slate-500 text-sm">
                No students found to generate cards for.
            </div>
        }
    </div>

</body>
</html>
