@page "{examId:guid}"
@model OpenCBT.Web.Pages.Admin.Exams.AnalyticsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = $"{Model.Analytics.ExamTitle} - Analytics";
}

<div class="space-y-8" x-data="{ activeTab: 'performances' }">
    <!-- Header Banner -->
    <div class="flex justify-between items-center bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
        <div>
            <span class="text-xs font-semibold uppercase tracking-wider text-primary">Exam Analytics</span>
            <h1 class="text-3xl font-extrabold text-slate-900 mt-1">@Model.Analytics.ExamTitle</h1>
            <p class="text-sm text-slate-500 mt-1">Real-time statistics, success rates, and item analysis.</p>
        </div>
        <div class="flex space-x-3">
            <a asp-page="./PrintGrades" asp-route-examId="@Model.Analytics.ExamId" target="_blank" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-semibold rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-all duration-200">
                Print Grades Roster
            </a>
            <a asp-page="./Index" class="inline-flex items-center px-4 py-2 border border-slate-300 rounded-lg text-sm font-semibold text-slate-700 bg-white hover:bg-slate-50 shadow-sm transition-all duration-200">
                Back to Exams
            </a>
        </div>
    </div>

    <!-- Analytics Dashboard Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-all duration-300">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Total Participants</span>
            <div class="flex items-baseline mt-4">
                <span class="text-4xl font-extrabold text-slate-800">@Model.Analytics.TotalParticipants</span>
                <span class="text-xs text-slate-400 font-semibold ml-2">students</span>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-100 flex justify-between items-center text-xs text-slate-500">
                <span>Completed: <strong>@Model.Analytics.CompletedCount</strong></span>
                <span class="px-2 py-0.5 rounded bg-blue-50 text-primary font-bold">@Model.Analytics.CompletionRate.ToString("0")%</span>
            </div>
        </div>

        <!-- Card 2 -->
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-all duration-300">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Average Class Score</span>
            <div class="flex items-baseline mt-4">
                <span class="text-4xl font-extrabold text-primary">@Model.Analytics.AverageScore.ToString("0.0")</span>
                <span class="text-xs text-slate-400 font-semibold ml-2">pts</span>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-100 text-xs text-slate-500">
                Standard overall grade metrics.
            </div>
        </div>

        <!-- Card 3 -->
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-all duration-300">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Highest Score</span>
            <div class="flex items-baseline mt-4">
                <span class="text-4xl font-extrabold text-green-600">@Model.Analytics.HighestScore.ToString("0.0")</span>
                <span class="text-xs text-slate-400 font-semibold ml-2">pts</span>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-100 text-xs text-slate-500">
                Top performance ceiling.
            </div>
        </div>

        <!-- Card 4 -->
        <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex flex-col justify-between hover:shadow-md transition-all duration-300">
            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">Lowest Score</span>
            <div class="flex items-baseline mt-4">
                <span class="text-4xl font-extrabold text-amber-600">@Model.Analytics.LowestScore.ToString("0.0")</span>
                <span class="text-xs text-slate-400 font-semibold ml-2">pts</span>
            </div>
            <div class="mt-4 pt-4 border-t border-slate-100 text-xs text-slate-500">
                Performance floor threshold.
            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="border-b border-slate-200">
        <nav class="-mb-px flex space-x-8" aria-label="Tabs">
            <button @@click="activeTab = 'performances'" 
                    :class="activeTab === 'performances' ? 'border-primary text-primary font-bold' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'"
                    class="whitespace-nowrap py-4 px-1 border-b-2 font-semibold text-sm">
                Student Performances (@Model.Analytics.StudentPerformances.Count)
            </button>
            <button @@click="activeTab = 'analysis'" 
                    :class="activeTab === 'analysis' ? 'border-primary text-primary font-bold' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'"
                    class="whitespace-nowrap py-4 px-1 border-b-2 font-semibold text-sm">
                Item Analysis (Question Metrics)
            </button>
            <button @@click="activeTab = 'charts'" 
                    :class="activeTab === 'charts' ? 'border-primary text-primary font-bold' : 'border-transparent text-slate-500 hover:text-slate-700 hover:border-slate-300'"
                    class="whitespace-nowrap py-4 px-1 border-b-2 font-semibold text-sm">
                Visual Charts
            </button>
        </nav>
    </div>

    <!-- Tab Panels -->
    <div>
        <!-- TAB 1: STUDENT PERFORMANCES -->
        <div x-show="activeTab === 'performances'" class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden transition-all duration-300">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Name / ID</th>
                            <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Started / Completed</th>
                            <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Status</th>
                            <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Score</th>
                            <th class="px-6 py-3 text-right text-xs font-bold text-slate-400 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        @foreach (var performance in Model.Analytics.StudentPerformances)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10 bg-slate-100 rounded-full flex items-center justify-center font-bold text-slate-600">
                                            @performance.FullName[0]
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-semibold text-slate-800">@performance.FullName</div>
                                            <div class="text-xs text-slate-400 font-mono">@performance.IdentifierNumber</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                    <div>@performance.StartedAt.ToLocalTime().ToString("g")</div>
                                    @if (performance.CompletedAt.HasValue)
                                    {
                                        <div class="text-xs text-slate-400 mt-1">Completed: @performance.CompletedAt.Value.ToLocalTime().ToString("g")</div>
                                    }
                                    else
                                    {
                                        <div class="text-xs text-amber-500 font-bold mt-1">In Progress</div>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (performance.CompletedAt.HasValue)
                                    {
                                        @if (performance.HasPendingEssays)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-1.5 rounded-full text-xs font-bold bg-amber-50 text-amber-700 border border-amber-200">
                                                Pending Essays
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-2.5 py-1.5 rounded-full text-xs font-bold bg-green-50 text-green-700 border border-green-200">
                                                Graded / Complete
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-1.5 rounded-full text-xs font-bold bg-blue-50 text-blue-700 border border-blue-200">
                                            Attempting
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-extrabold text-slate-800">
                                        @(performance.Score?.ToString("0.0") ?? "-")
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    @if (performance.CompletedAt.HasValue)
                                    {
                                        <a asp-page="./GradeEssay" asp-route-sessionId="@performance.SessionId" class="inline-flex items-center px-3 py-1.5 border border-primary text-xs font-semibold rounded-lg text-primary bg-white hover:bg-blue-50 transition-all shadow-sm">
                                            @(performance.HasPendingEssays ? "Grade Essays" : "View / Edit Grades")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-xs text-slate-400 italic">Cannot grade active exam</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- TAB 2: ITEM ANALYSIS -->
        <div x-show="activeTab === 'analysis'" class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden transition-all duration-300">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Question Prompt</th>
                            <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Type</th>
                            <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Max Points</th>
                            <th class="px-6 py-3 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Success Rate / Class Accuracy</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        @foreach (var item in Model.Analytics.ItemAnalysis)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4 text-sm font-medium text-slate-800 max-w-md truncate">
                                    @item.QuestionText
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded text-xs font-bold @(item.QuestionType == "Essay" ? "bg-purple-100 text-purple-800" : "bg-blue-100 text-blue-800")">
                                        @item.QuestionType
                                    </span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 font-mono">
                                    @item.Points.ToString("0") pts
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center space-x-3">
                                        <div class="w-24 bg-slate-200 rounded-full h-2 shadow-inner overflow-hidden">
                                            <div class="h-2 rounded-full @(item.SuccessRatePercent >= 70 ? "bg-green-500" : (item.SuccessRatePercent >= 40 ? "bg-amber-500" : "bg-red-500"))" 
                                                 style="width: @item.SuccessRatePercent%"></div>
                                        </div>
                                        <span class="text-xs font-extrabold text-slate-700 font-mono">
                                            @item.SuccessRatePercent.ToString("0")%
                                        </span>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <!-- TAB 3: VISUAL CHARTS -->
        <div x-show="activeTab === 'charts'" class="bg-white border border-slate-200 rounded-xl shadow-sm p-6 transition-all duration-300">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <!-- Grade Distribution Pie Chart -->
                <div class="flex flex-col items-center">
                    <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wider mb-4">Grade Distribution</h3>
                    <div class="relative w-full max-w-xs aspect-square">
                        <canvas id="gradeDistributionChart"></canvas>
                    </div>
                </div>
                <!-- Question Success Rate Bar Chart -->
                <div class="flex flex-col items-center">
                    <h3 class="text-sm font-bold text-slate-700 uppercase tracking-wider mb-4">Question Success Rates</h3>
                    <div class="relative w-full h-64">
                        <canvas id="questionSuccessChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('alpine:init', () => {
            // Data from Model
            const performances = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Analytics.StudentPerformances.Where(p => p.CompletedAt.HasValue && p.Score.HasValue).Select(p => p.Score.Value)));
            const items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Analytics.ItemAnalysis));

            // Grade Distribution (A: >80, B: 60-80, C: 40-60, D: <40)
            let grades = { A: 0, B: 0, C: 0, D: 0 };
            performances.forEach(score => {
                if (score >= 80) grades.A++;
                else if (score >= 60) grades.B++;
                else if (score >= 40) grades.C++;
                else grades.D++;
            });

            // Render Pie Chart
            const ctxPie = document.getElementById('gradeDistributionChart').getContext('2d');
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: ['A (≥80)', 'B (60-79)', 'C (40-59)', 'D (<40)'],
                    datasets: [{
                        data: [grades.A, grades.B, grades.C, grades.D],
                        backgroundColor: ['#22c55e', '#3b82f6', '#f59e0b', '#ef4444'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });

            // Render Bar Chart
            const ctxBar = document.getElementById('questionSuccessChart').getContext('2d');
            new Chart(ctxBar, {
                type: 'bar',
                data: {
                    labels: items.map((item, index) => 'Q' + (index + 1)),
                    datasets: [{
                        label: 'Success Rate (%)',
                        data: items.map(item => item.SuccessRatePercent),
                        backgroundColor: '#6366f1',
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 100
                        }
                    },
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return context.raw.toFixed(1) + '%';
                                }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
