@page
@using Microsoft.AspNetCore.Identity
@using OpenCBT.Domain.Entities
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@inject SignInManager<ApplicationUser> SignInManager
@model IndexModel
@{
    ViewData["Title"] = Localizer["Dashboard"];
}

<div class="text-center mb-12 mt-10">
    <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl sm:tracking-tight lg:text-6xl">
        @Localizer["WelcomeTitle"]
    </h1>
    <p class="mt-5 max-w-xl mx-auto text-xl text-gray-500">
        @Localizer["WelcomeSubtitle"]
    </p>

    @if (!SignInManager.IsSignedIn(User))
    {
        <div class="mt-8">
            <a asp-page="/Account/Login" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary hover:bg-blue-700 shadow-lg transition-colors md:py-4 md:text-lg md:px-10">
                @Localizer["LoginToStart"]
            </a>
        </div>
    }
</div>

@if (SignInManager.IsSignedIn(User))
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Card 1: My Exams -->
        <!-- My Exams Card -->
        <div class="bg-white overflow-hidden shadow rounded-lg hover:shadow-md transition-shadow">
            <div class="p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-primary rounded-md p-3">
                        <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    <div class="ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-sm font-medium text-gray-500 truncate">Upcoming & Active</dt>
                            <dd class="flex items-baseline">
                                <div class="text-2xl font-semibold text-gray-900">My Exams</div>
                            </dd>
                        </dl>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 px-5 py-3">
                <div class="text-sm">
                    <a asp-page="/Exams/Index" class="font-medium text-primary hover:text-blue-700">View all exams</a>
                </div>
            </div>
        </div>
    </div>
}
