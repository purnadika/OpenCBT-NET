@page "{sessionId:guid}"
@model OpenCBT.Web.Pages.Exams.ReportCardModel
@{
    ViewData["Title"] = $"Report Card: {Model.ReportDetails.ExamTitle}";
    // Use a blank layout or hide main layout elements if standard layout is applied
    Layout = "_Layout";
}

<style>
    @@media print {
        body {
            background-color: white;
            -webkit-print-color-adjust: exact;
        }
        .no-print {
            display: none !important;
        }
        .print-only {
            display: block !important;
        }
        .report-card-container {
            box-shadow: none !important;
            border: none !important;
            padding: 0 !important;
            margin: 0 !important;
        }
        /* Hide navbar and footers usually present in _Layout */
        header, footer, nav {
            display: none !important;
        }
        main {
            padding: 0 !important;
            margin: 0 !important;
        }
    }
    
    .print-only {
        display: none;
    }
</style>

<div class="max-w-4xl mx-auto py-8 sm:px-6 lg:px-8 no-print">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Certificate of Completion</h1>
        <div>
            <a asp-page="./Index" class="inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 mr-3">
                Back to Dashboard
            </a>
            <button onclick="window.print()" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary hover:bg-blue-700">
                <svg class="mr-2 -ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path>
                </svg>
                Print / Save PDF
            </button>
        </div>
    </div>
</div>

<div class="max-w-4xl mx-auto bg-white shadow-xl sm:rounded-lg overflow-hidden border border-gray-200 report-card-container">
    
    <!-- Report Header Banner -->
    <div class="bg-primary px-8 py-10 text-white flex justify-between items-center border-b-8 border-amber-500">
        <div>
            <h2 class="text-4xl font-extrabold tracking-tight">OFFICIAL SCORE REPORT</h2>
            <p class="mt-2 text-blue-100 text-lg">OpenCBT Examination System</p>
        </div>
        <div class="text-right">
            <h3 class="text-xl font-bold">@Model.ReportDetails.ExamTitle</h3>
            <p class="text-blue-100 mt-1">Generated: @DateTime.UtcNow.ToString("dd MMM yyyy")</p>
        </div>
    </div>

    <!-- Student Details -->
    <div class="px-8 py-8 grid grid-cols-2 gap-8 border-b border-gray-200">
        <div>
            <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Student Name</h4>
            <p class="text-xl font-bold text-gray-900">@Model.ReportDetails.StudentName</p>
        </div>
        <div>
            <h4 class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-1">Student Identifier (NISN)</h4>
            <p class="text-xl font-bold text-gray-900">@Model.ReportDetails.StudentIdentifier</p>
        </div>
    </div>

    <!-- Grade Summary -->
    <div class="px-8 py-8 bg-gray-50 grid grid-cols-3 gap-6 border-b border-gray-200 text-center">
        <div>
            <h4 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Total Score</h4>
            <p class="mt-2 text-4xl font-extrabold text-gray-900">@Model.ReportDetails.TotalScore <span class="text-lg text-gray-400">/ @Model.MaxScore</span></p>
        </div>
        <div>
            <h4 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Percentage</h4>
            <p class="mt-2 text-4xl font-extrabold text-gray-900">@Model.Percentage.ToString("0.0")%</p>
        </div>
        <div>
            <h4 class="text-sm font-medium text-gray-500 uppercase tracking-wider">Classification</h4>
            @if (Model.IsPassed)
            {
                <p class="mt-2 text-4xl font-extrabold text-green-600">PASS</p>
            }
            else
            {
                <p class="mt-2 text-4xl font-extrabold text-red-600">FAIL</p>
            }
        </div>
    </div>

    <!-- Roster of Questions & Answers -->
    <div class="px-8 py-8">
        <h3 class="text-lg font-bold text-gray-900 mb-6 border-b pb-2">Response Breakdown</h3>
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">No</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Question / Type</th>
                    <th scope="col" class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Your Answer</th>
                    <th scope="col" class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Points</th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @{ int qIndex = 1; }
                @foreach (var response in Model.ReportDetails.Responses)
                {
                    <tr>
                        <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-900 font-medium">@qIndex</td>
                        <td class="px-4 py-4 text-sm text-gray-700">
                            <div class="line-clamp-2" title="@response.QuestionText">@response.QuestionText</div>
                            <span class="text-xs text-gray-400">@response.QuestionType</span>
                        </td>
                        <td class="px-4 py-4 text-sm text-gray-900">
                            @if (response.QuestionType == "MULTIPLE_CHOICE")
                            {
                                if (response.IsMultipleChoiceCorrect)
                                {
                                    <span class="inline-flex items-center text-green-700 font-medium">
                                        <svg class="mr-1.5 h-4 w-4 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
                                        @response.SelectedOptionText
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center text-red-700 font-medium">
                                        <svg class="mr-1.5 h-4 w-4 text-red-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
                                        @response.SelectedOptionText
                                    </span>
                                    <div class="text-xs text-gray-500 mt-1">Correct: @response.CorrectOptionText</div>
                                }
                            }
                            else
                            {
                                <div class="italic text-gray-600">@response.EssayAnswer</div>
                                @if (!string.IsNullOrEmpty(response.TeacherFeedback))
                                {
                                    <div class="mt-2 p-2 bg-yellow-50 text-xs text-yellow-800 border-l-2 border-yellow-400">
                                        <strong>Feedback:</strong> @response.TeacherFeedback
                                    </div>
                                }
                            }
                        </td>
                        <td class="px-4 py-4 whitespace-nowrap text-center text-sm font-bold @(response.PointsObtained > 0 ? "text-green-600" : "text-gray-500")">
                            @response.PointsObtained <span class="text-xs font-normal text-gray-400">/ @response.MaxPoints</span>
                        </td>
                    </tr>
                    qIndex++;
                }
            </tbody>
        </table>
    </div>

    <!-- Verification / Signature Block -->
    <div class="px-8 py-10 bg-gray-50 grid grid-cols-2 gap-12 border-t border-gray-200">
        <div>
            <div class="mb-16">
                <h5 class="text-sm font-bold text-gray-900 mb-2">Authenticated By</h5>
                <p class="text-xs text-gray-500">This report card is generated electronically and is valid without a physical seal if verified through the OpenCBT portal.</p>
            </div>
            <div class="border-t border-gray-400 pt-2 w-64 text-center">
                <p class="text-sm font-bold text-gray-900">Examination Proctor</p>
                <p class="text-xs text-gray-500">Signature</p>
            </div>
        </div>
        <div class="text-right">
            <!-- Simulated QR Code visual (In production, replace with actual QR image generator) -->
            <div class="inline-block p-2 bg-white border border-gray-300 shadow-sm rounded-lg mb-2">
                <svg class="h-24 w-24 text-gray-900" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M3 3h8v8H3V3zm2 2v4h4V5H5zm8-2h8v8h-8V3zm2 2v4h4V5h-4zM3 13h8v8H3v-8zm2 2v4h4v-4H5zm13-2h3v3h-3v-3zm-2 3h3v3h-3v-3zm3 3h3v3h-3v-3zm-5-3h3v3h-3v-3zm0-5h3v3h-3v-3zm-2 2h3v3h-3v-3zm-2-2h3v3h-3v-3zm-2 5h3v3h-3v-3zm2-3h3v3h-3v-3z"></path>
                </svg>
            </div>
            <p class="text-xs font-mono text-gray-500">VERIFY: @Model.ReportDetails.SessionId.ToString().Substring(0,8).ToUpper()</p>
        </div>
    </div>
</div>
