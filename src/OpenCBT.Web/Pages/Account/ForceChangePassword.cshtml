@page
@model OpenCBT.Web.Pages.Account.ForceChangePasswordModel
@{
    ViewData["Title"] = "Update Password Required";
}

<div class="min-h-full flex flex-col justify-center py-12 sm:px-6 lg:px-8 bg-gray-50">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
        <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
            Welcome to OpenCBT!
        </h2>
        <p class="mt-2 text-center text-sm text-gray-600">
            For security reasons, you must change your auto-generated password before continuing.
        </p>
    </div>

    <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
        <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
            <form method="post" class="space-y-6">
                <input type="hidden" asp-for="Input.Email" />
                <input type="hidden" asp-for="Input.Token" />
                <input type="hidden" asp-for="Input.ReturnUrl" />

                <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 font-medium"></div>

                <div>
                    <label asp-for="Input.NewPassword" class="block text-sm font-medium text-gray-700">New Password</label>
                    <div class="mt-1">
                        <input asp-for="Input.NewPassword" class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" />
                        <span asp-validation-for="Input.NewPassword" class="text-xs text-red-600"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-700">Confirm New Password</label>
                    <div class="mt-1">
                        <input asp-for="Input.ConfirmPassword" class="appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-xs text-red-600"></span>
                    </div>
                </div>

                <div>
                    <button type="submit" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-primary hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary">
                        Update Password & Continue
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
