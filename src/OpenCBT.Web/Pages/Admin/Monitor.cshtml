@page
@model OpenCBT.Web.Pages.Admin.MonitorModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = $"Monitoring: {Model.Exam.Title}";
}

<div class="mb-8 flex justify-between items-center" x-data="proctorMonitor()">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">Live Proctor Monitor</h1>
        <p class="text-sm text-gray-500">Real-time status for: <strong>@Model.Exam.Title</strong></p>
    </div>
    <div class="flex items-center space-x-3">
        @if (Model.Exam.TokenRequired)
        {
            <div class="bg-blue-50 border border-blue-200 rounded-md px-3 py-1.5 text-sm font-semibold text-blue-700 font-mono">
                Active Token: @Model.Exam.CurrentToken
            </div>
        }
        <button @@click="openBroadcastModal = true" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-amber-600 hover:bg-amber-700">
            Broadcast Announcement
        </button>
        <button @@click="forceSubmitAll()" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700">
            Force Submit All
        </button>
    </div>

    <!-- Broadcast Modal -->
    <div x-show="openBroadcastModal" class="fixed z-10 inset-0 overflow-y-auto" style="display: none;">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 transition-opacity" aria-hidden="true">
                <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
            </div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div class="inline-block align-bottom bg-white rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6">
                <div>
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Send Broadcast Announcement</h3>
                    <p class="text-xs text-gray-500 mb-2">This will display as a persistent notification on all active students' screens.</p>
                    <textarea x-model="broadcastMessage" rows="3" class="block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-primary focus:border-primary sm:text-sm" placeholder="Enter announcement..."></textarea>
                </div>
                <div class="mt-5 sm:mt-6 sm:grid sm:grid-cols-2 sm:gap-3">
                    <button type="button" @@click="sendBroadcast(); openBroadcastModal = false" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-amber-600 text-base font-medium text-white hover:bg-amber-700 sm:text-sm">
                        Broadcast
                    </button>
                    <button type="button" @@click="openBroadcastModal = false" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 sm:mt-0 sm:text-sm">
                        Cancel
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Students Real-time Dashboard Grid -->
    <div class="w-full mt-8">
        <h2 class="text-xl font-bold text-gray-900 mb-4">Active Students (<span x-text="students.length"></span>)</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            <template x-for="student in students" :key="student.connectionId">
                <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200">
                    <div class="p-5 flex flex-col justify-between h-44">
                        <div>
                            <div class="flex justify-between items-center mb-2">
                                <h3 class="text-sm font-semibold text-gray-900 truncate" x-text="student.name"></h3>
                                <span class="px-2 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Online</span>
                            </div>
                            <div class="text-xs text-gray-500 mb-4">
                                Current Position: Question <span x-text="student.questionIndex + 1"></span> of <span x-text="student.totalQuestions"></span>
                            </div>
                            
                            <!-- Progress Bar -->
                            <div class="w-full bg-gray-200 rounded-full h-2.5">
                                <div class="bg-primary h-2.5 rounded-full" :style="'width: ' + ((student.questionIndex + 1) / student.totalQuestions * 100) + '%'"></div>
                            </div>
                        </div>

                        <div class="flex justify-between items-center border-t pt-3 mt-4">
                            <button @@click="openChatWithStudent(student)" class="inline-flex items-center text-xs font-semibold text-blue-600 hover:text-blue-800">
                                Chat
                            </button>
                            <button @@click="forceSubmit(student.connectionId)" class="inline-flex items-center text-xs font-semibold text-red-600 hover:text-red-800">
                                Force Submit
                            </button>
                        </div>
                    </div>
                </div>
            </template>
        </div>

        <template x-if="students.length === 0">
            <div class="bg-slate-50 border border-slate-200 rounded-md p-8 text-center text-slate-500 text-sm">
                No active students connected to the proctoring room.
            </div>
        </template>
    </div>

    <!-- Active 1-to-1 Chat Widget overlay -->
    <div x-show="activeChatStudent" class="fixed bottom-4 right-4 z-50 bg-white shadow-2xl rounded-lg border border-slate-200 overflow-hidden w-80" style="display: none;">
        <div class="bg-primary text-white py-3 px-4 font-bold flex justify-between items-center">
            <span x-text="'Chat with ' + (activeChatStudent ? activeChatStudent.name : '')"></span>
            <button @@click="activeChatStudent = null" class="text-white hover:text-gray-200 font-bold">&times;</button>
        </div>
        <div class="p-3 flex flex-col h-72">
            <div class="flex-1 overflow-y-auto space-y-2 mb-3 bg-slate-50 p-2 rounded text-xs">
                <template x-for="chat in chats" :key="chat.id">
                    <div :class="chat.sentByMe ? 'text-right' : 'text-left'">
                        <span class="inline-block px-2.5 py-1.5 rounded-lg max-w-[80%]" :class="chat.sentByMe ? 'bg-blue-100 text-blue-800' : 'bg-slate-200 text-slate-800'" x-text="chat.text"></span>
                    </div>
                </template>
            </div>
            <div class="flex">
                <input type="text" x-model="chatMsg" @@keyup.enter="sendChat(); chatMsg=''" placeholder="Type message..." class="border border-slate-300 rounded-l-md px-2 py-1 text-xs w-full focus:outline-none focus:ring-1 focus:ring-primary">
                <button @@click="sendChat(); chatMsg=''" class="bg-primary text-white text-xs px-3 rounded-r-md">Send</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('proctorMonitor', () => ({
                examId: '@Model.Exam.Id',
                connection: null,
                students: [],

                // UI Controls
                openBroadcastModal: false,
                broadcastMessage: '',

                // Chat States
                activeChatStudent: null,
                chats: [],
                chatMsg: '',

                init() {
                    this.connection = new signalR.HubConnectionBuilder()
                        .withUrl("/proctorHub")
                        .build();

                    this.connection.on("StudentConnected", (connectionId, name) => {
                        if (!this.students.some(s => s.connectionId == connectionId)) {
                             this.students.push({ connectionId, name: name || "Student", questionIndex: 0, totalQuestions: 1 });
                        }
                    });

                    this.connection.on("StudentProgressUpdated", (connectionId, studentName, questionIndex, totalQuestions) => {
                        const idx = this.students.findIndex(s => s.connectionId == connectionId);
                        if (idx !== -1) {
                            this.students[idx].questionIndex = questionIndex;
                            this.students[idx].totalQuestions = totalQuestions;
                        } else {
                            this.students.push({ connectionId, name: studentName, questionIndex, totalQuestions });
                        }
                    });

                    this.connection.on("StudentReplyReceived", (studentConnectionId, studentName, message) => {
                        if (this.activeChatStudent && this.activeChatStudent.connectionId === studentConnectionId) {
                            this.chats.push({ id: Date.now(), text: message, sentByMe: false });
                        } else {
                            // Automatically popup chat
                            this.activeChatStudent = { connectionId: studentConnectionId, name: studentName };
                            this.chats = [{ id: Date.now(), text: message, sentByMe: false }];
                        }
                    });

                    this.connection.start().then(() => {
                        this.connection.invoke("JoinExamRoom", this.examId, "Proctor");
                    }).catch(err => console.error(err.toString()));
                },

                sendBroadcast() {
                    if (!this.broadcastMessage || this.broadcastMessage.trim() === "") return;
                    this.connection.invoke("SendBroadcastMessage", this.examId, this.broadcastMessage);
                    this.broadcastMessage = '';
                },

                openChatWithStudent(student) {
                    this.activeChatStudent = student;
                    this.chats = [];
                },

                sendChat() {
                    if (!this.chatMsg || this.chatMsg.trim() === "" || !this.activeChatStudent) return;
                    this.chats.push({ id: Date.now(), text: this.chatMsg, sentByMe: true });
                    this.connection.invoke("SendPersonalMessage", this.activeChatStudent.connectionId, this.chatMsg);
                },

                forceSubmit(studentConnectionId) {
                    if(confirm("Are you sure you want to force this student to submit immediately?")) {
                         this.connection.invoke("ForceSubmitStudent", studentConnectionId);
                    }
                },

                forceSubmitAll() {
                    if(confirm("WARNING: This will instantly submit the exam for ALL connected students. Are you sure?")) {
                         this.connection.invoke("ForceSubmitAll", this.examId);
                    }
                }
            }))
        })
    </script>
}
