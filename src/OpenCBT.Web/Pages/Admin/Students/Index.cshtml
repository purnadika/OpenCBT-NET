@page
@model OpenCBT.Web.Pages.Admin.Students.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Students";
}

<div x-data="{ 
    openCreateModal: false, 
    openEditModal: false, 
    openPasswordModal: @(Model.TemporaryPassword != null ? "true" : "false"),
    editStudent: { id: '', fullName: '', email: '', identifierNumber: '', isActive: true },
    triggerEdit(student) {
        this.editStudent = { ...student };
        this.openEditModal = true;
    }
}">

    <div class="mb-8 flex justify-between items-center">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Manage Students</h1>
            <p class="text-sm text-gray-500">Register new students, update credentials, and reset passwords.</p>
        </div>
        <div class="flex space-x-3">
            <a asp-page="./PrintCards" target="_blank" class="inline-flex items-center px-4 py-2 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 transition">
                Print Exam Cards
            </a>
            <a asp-page="./Import" class="inline-flex items-center px-4 py-2 border border-slate-300 shadow-sm text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 transition">
                Bulk Import
            </a>
            <button @@click="openCreateModal = true" class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary hover:bg-blue-700 transition">
                Register Student
            </button>
        </div>
    </div>

    <!-- Error Summary Alerts -->
    @if (!ModelState.IsValid)
    {
        <div class="mb-6 p-4 bg-red-50 border-l-4 border-red-400 rounded-md">
            <div class="flex">
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">Please correct the errors before proceeding:</h3>
                    <div asp-validation-summary="All" class="mt-2 text-xs text-red-700 list-disc list-inside"></div>
                </div>
            </div>
        </div>
    }

    <!-- Temporary Password Reset Success Modal -->
    <div x-show="openPasswordModal" class="fixed z-20 inset-0 overflow-y-auto" style="display: none;" x-transition>
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 transition-opacity" aria-hidden="true">
                <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
            </div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div class="inline-block align-bottom bg-white rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6">
                <div class="text-center">
                    <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-green-100 mb-4">
                        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <h3 class="text-lg leading-6 font-medium text-gray-900">Password Reset Successful</h3>
                    <p class="mt-2 text-sm text-gray-500">A new secure temporary password has been generated for <strong>@Model.ResetStudentName</strong>:</p>
                    <div class="mt-4 p-3 bg-gray-50 border border-gray-200 rounded-md font-mono text-lg font-bold select-all tracking-wider text-slate-800">
                        @Model.TemporaryPassword
                    </div>
                    <p class="mt-2 text-xs text-red-500 font-semibold">Copy this password now. It will not be shown again.</p>
                </div>
                <div class="mt-6">
                    <button type="button" @@click="openPasswordModal = false" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary text-base font-medium text-white hover:bg-blue-700 sm:text-sm transition">
                        Dismiss
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Student Modal -->
    <div x-show="openCreateModal" class="fixed z-10 inset-0 overflow-y-auto" style="display: none;" x-transition>
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 transition-opacity" aria-hidden="true">
                <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
            </div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div class="inline-block align-bottom bg-white rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6">
                <form method="post" asp-page-handler="Create">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Register Student</h3>
                    <div class="space-y-4">
                        <div>
                            <label asp-for="NewStudent.FullName" class="block text-sm font-medium text-gray-700">Full Name</label>
                            <input asp-for="NewStudent.FullName" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm">
                        </div>
                        <div>
                            <label asp-for="NewStudent.Email" class="block text-sm font-medium text-gray-700">Email Address</label>
                            <input asp-for="NewStudent.Email" type="email" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm">
                        </div>
                        <div>
                            <label asp-for="NewStudent.IdentifierNumber" class="block text-sm font-medium text-gray-700">NISN / ID Number</label>
                            <input asp-for="NewStudent.IdentifierNumber" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm">
                        </div>
                        <div>
                            <label asp-for="NewStudent.Password" class="block text-sm font-medium text-gray-700">Password</label>
                            <input asp-for="NewStudent.Password" type="password" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm">
                        </div>
                    </div>
                    <div class="mt-5 sm:mt-6 sm:grid sm:grid-cols-2 sm:gap-3 sm:grid-flow-row-dense">
                        <button type="submit" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary text-base font-medium text-white hover:bg-blue-700 sm:col-start-2 sm:text-sm transition">
                            Register
                        </button>
                        <button type="button" @@click="openCreateModal = false" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 sm:mt-0 sm:col-start-1 sm:text-sm transition">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Edit Student Modal -->
    <div x-show="openEditModal" class="fixed z-10 inset-0 overflow-y-auto" style="display: none;" x-transition>
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 transition-opacity" aria-hidden="true">
                <div class="absolute inset-0 bg-gray-500 opacity-75"></div>
            </div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div class="inline-block align-bottom bg-white rounded-lg px-4 pt-5 pb-4 text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full sm:p-6">
                <form method="post" asp-page-handler="Update">
                    <input type="hidden" name="EditStudent.Id" x-model="editStudent.id">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Edit Student Information</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Full Name</label>
                            <input name="EditStudent.FullName" x-model="editStudent.fullName" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700">Email Address</label>
                            <input name="EditStudent.Email" type="email" x-model="editStudent.email" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700">NISN / ID Number</label>
                            <input name="EditStudent.IdentifierNumber" x-model="editStudent.identifierNumber" required class="mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:outline-none focus:ring-primary focus:border-primary sm:text-sm">
                        </div>
                        <div class="flex items-center space-x-2">
                            <input type="checkbox" name="EditStudent.IsActive" x-model="editStudent.isActive" id="EditIsActive" class="h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded">
                            <label for="EditIsActive" class="text-sm font-medium text-gray-700">Is Active / Allowed to log in</label>
                        </div>
                    </div>
                    <div class="mt-5 sm:mt-6 sm:grid sm:grid-cols-2 sm:gap-3 sm:grid-flow-row-dense">
                        <button type="submit" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary text-base font-medium text-white hover:bg-blue-700 sm:col-start-2 sm:text-sm transition">
                            Save Changes
                        </button>
                        <button type="button" @@click="openEditModal = false" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 shadow-sm px-4 py-2 bg-white text-base font-medium text-gray-700 hover:bg-gray-50 sm:mt-0 sm:col-start-1 sm:text-sm transition">
                            Cancel
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Table Roster -->
    <div class="bg-white shadow overflow-hidden sm:rounded-md border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Full Name</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID Number</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th scope="col" class="relative px-6 py-3">
                        <span class="sr-only">Actions</span>
                    </th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                @foreach (var student in Model.Students)
                {
                    <tr>
                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">@student.FullName</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@student.Email</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">@student.IdentifierNumber</td>
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            @if (student.IsActive)
                            {
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">Active</span>
                            }
                            else
                            {
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">Disabled</span>
                            }
                        </td>
                        <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium space-x-3">
                            <button type="button" @@click="triggerEdit({ id: '@student.Id', fullName: '@student.FullName', email: '@student.Email', identifierNumber: '@student.IdentifierNumber', isActive: @(student.IsActive ? "true" : "false") })" class="text-primary hover:text-blue-900 font-medium">Edit</button>

                            <form method="post" asp-page-handler="ResetPassword" asp-route-id="@student.Id" asp-route-studentName="@student.FullName" onsubmit="return confirm('Are you sure you want to reset the password for @student.FullName?');" class="inline-block">
                                <button type="submit" class="text-amber-600 hover:text-amber-900 font-medium">Reset Password</button>
                            </form>

                            <form method="post" asp-page-handler="Delete" asp-route-id="@student.Id" onsubmit="return confirm('Are you sure you want to delete this student? All their exam history will be deleted.');" class="inline-block">
                                <button type="submit" class="text-red-600 hover:text-red-900 font-medium">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Students.Any())
                {
                    <tr>
                        <td colspan="5" class="px-6 py-8 text-center text-gray-500 text-sm">No students registered yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
