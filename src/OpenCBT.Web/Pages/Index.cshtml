@page
@using Microsoft.AspNetCore.Identity
@using OpenCBT.Domain.Entities
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@inject SignInManager<ApplicationUser> SignInManager
@model IndexModel
@{
    ViewData["Title"] = Localizer["Dashboard"];
}

<div class="text-center mb-12 mt-10">
    <h1 class="text-4xl font-extrabold text-gray-900 sm:text-5xl sm:tracking-tight lg:text-6xl">
        @Localizer["WelcomeTitle"]
    </h1>
    <p class="mt-5 max-w-xl mx-auto text-xl text-gray-500">
        @Localizer["WelcomeSubtitle"]
    </p>

    @if (!SignInManager.IsSignedIn(User))
    {
        <div class="mt-8">
            <a asp-page="/Account/Login" class="inline-flex items-center justify-center px-8 py-3 border border-transparent text-base font-medium rounded-md text-white bg-primary hover:bg-blue-700 shadow-lg transition-colors md:py-4 md:text-lg md:px-10">
                @Localizer["LoginToStart"]
            </a>
        </div>
    }
</div>

@if (SignInManager.IsSignedIn(User))
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Card 1: My Exams -->
        <a asp-page="/Exams/Index" class="block bg-white shadow overflow-hidden sm:rounded-lg hover:shadow-md transition-shadow duration-300">
            <div class="px-4 py-5 sm:p-6 text-center">
                <div class="text-5xl mb-4">&#128221;</div>
                <h3 class="text-lg leading-6 font-medium text-gray-900">@Localizer["Card1Title"]</h3>
                <div class="mt-2 text-sm text-gray-500">
                    <p>@Localizer["Card1Desc"]</p>
                </div>
            </div>
        </a>

        <!-- Card 2: Practice (Mock) -->
        <a href="#" class="block bg-white shadow overflow-hidden sm:rounded-lg hover:shadow-md transition-shadow duration-300 opacity-50 cursor-not-allowed">
            <div class="px-4 py-5 sm:p-6 text-center">
                <div class="text-5xl mb-4">&#127919;</div>
                <h3 class="text-lg leading-6 font-medium text-gray-900">@Localizer["Card2Title"]</h3>
                <div class="mt-2 text-sm text-gray-500">
                    <p>@Localizer["Card2Desc"]</p>
                </div>
            </div>
        </a>

        <!-- Card 3: Results -->
        <a href="#" class="block bg-white shadow overflow-hidden sm:rounded-lg hover:shadow-md transition-shadow duration-300 opacity-50 cursor-not-allowed">
            <div class="px-4 py-5 sm:p-6 text-center">
                <div class="text-5xl mb-4">&#128202;</div>
                <h3 class="text-lg leading-6 font-medium text-gray-900">@Localizer["Card3Title"]</h3>
                <div class="mt-2 text-sm text-gray-500">
                    <p>@Localizer["Card3Desc"]</p>
                </div>
            </div>
        </a>

        <!-- Card 4: Study Materials (Mock) -->
        <a href="#" class="block bg-white shadow overflow-hidden sm:rounded-lg hover:shadow-md transition-shadow duration-300 opacity-50 cursor-not-allowed">
            <div class="px-4 py-5 sm:p-6 text-center">
                <div class="text-5xl mb-4">&#128218;</div>
                <h3 class="text-lg leading-6 font-medium text-gray-900">@Localizer["Card4Title"]</h3>
                <div class="mt-2 text-sm text-gray-500">
                    <p>@Localizer["Card4Desc"]</p>
                </div>
            </div>
        </a>

        <!-- Card 5: Profile -->
        <a href="#" class="block bg-white shadow overflow-hidden sm:rounded-lg hover:shadow-md transition-shadow duration-300 opacity-50 cursor-not-allowed">
            <div class="px-4 py-5 sm:p-6 text-center">
                <div class="text-5xl mb-4">&#128100;</div>
                <h3 class="text-lg leading-6 font-medium text-gray-900">@Localizer["Card5Title"]</h3>
                <div class="mt-2 text-sm text-gray-500">
                    <p>@Localizer["Card5Desc"]</p>
                </div>
            </div>
        </a>

        <!-- Card 6: Help & Support -->
        <a href="#" class="block bg-white shadow overflow-hidden sm:rounded-lg hover:shadow-md transition-shadow duration-300 opacity-50 cursor-not-allowed">
            <div class="px-4 py-5 sm:p-6 text-center">
                <div class="text-5xl mb-4">&#10067;</div>
                <h3 class="text-lg leading-6 font-medium text-gray-900">@Localizer["Card6Title"]</h3>
                <div class="mt-2 text-sm text-gray-500">
                    <p>@Localizer["Card6Desc"]</p>
                </div>
            </div>
        </a>
    </div>
}
